<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Emmy Blog - <%= title %></title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    
    <%- include('navbar') %>

    <main class="container">
        <h1>Blog Details</h1>
        <div class="blogs">
            <% blog.forEach(blog => { %>
                <div class="blog">
        
                        <h2><%= blog.title %></h2>
                        <p><%= blog.snippet %></p>
                        <p><%= blog.body %></p>
                    
                        <button><a href="/">Back</a></button>
                </div>
            <% }); %>
        </div>
    </main>
</body>
</html>