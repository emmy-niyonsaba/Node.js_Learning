<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Emmy Blog - <%= title %></title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    
    <%- include('navbar') %>

    <main class="container">
        <h1>All blogs</h1>
        <div class="blogs">
            <% blogs.forEach(blog => { %>
                <div class="blog">
                    <h3><%= blog.title %></h3>
                    <p><%= blog.snippet %></p>
                </div>
            <% }); %>
        </div>
    </main>
</body>
</html>